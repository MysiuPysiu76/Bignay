{
  "schemaVersion": 1,
  "id": "bignay",
  "version": "${version}",
  "name": "Bignay",
  "description": "A lightweight mod that adds missing blocks and items to improve your Minecraft experience.\n\n",
  "authors": ["MysiuPysiu"],
  "contact": {},
  "license": "GNU GPL 3.0",
  "icon": "pack.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.mysiupysiu.bignay.fabric.BignayFabric"
    ],
    "client": [
      "com.mysiupysiu.bignay.fabric.client.BignayFabricClient"
    ],
    "modmenu": [
      "com.mysiupysiu.bignay.fabric.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "bignay.mixins.json",
    "bignay-common.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.0",
    "minecraft": ">=1.20.1"
  }
}